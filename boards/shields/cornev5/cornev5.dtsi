#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/gpio/gpio.h>
#include "cornev5-layouts.dtsi"

/ {
    chosen {
        zmk,kscan = <&kscan0>;
        zmk,matrix-transform = <&default_transform>;
        zmk,physical-layout = <&cornev5_layout>;
    };

    kscan0: kscan_matrix {
        compatible = "zmk,kscan-gpio-matrix";
        status = "okay";
        wakeup-source;
        diode-direction = "col2row";
        row-gpios =
            <&gpio0 4 GPIO_ACTIVE_HIGH>,
            <&gpio0 5 GPIO_ACTIVE_HIGH>,
            <&gpio0 6 GPIO_ACTIVE_HIGH>,
            <&gpio0 7 GPIO_ACTIVE_HIGH>;
        col-gpios =
            <&gpio0 10 GPIO_ACTIVE_HIGH>,
            <&gpio0 11 GPIO_ACTIVE_HIGH>,
            <&gpio0 12 GPIO_ACTIVE_HIGH>,
            <&gpio0 13 GPIO_ACTIVE_HIGH>,
            <&gpio0 14 GPIO_ACTIVE_HIGH>,
            <&gpio0 15 GPIO_ACTIVE_HIGH>;
    };

    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <4>;
        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)  RC(3,0)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10) RC(0,11) RC(3,9)
            RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)  RC(3,1)  RC(1,6)  RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10) RC(1,11) RC(3,10)
            RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)                    RC(2,7)  RC(2,8)  RC(2,9)  RC(2,10) RC(2,11) RC(3,11)
                                       RC(3,3)  RC(3,4)  RC(3,5)                    RC(3,6)  RC(3,7)  RC(3,8)
        >;
    };
};
